# name: test/sql/gh_network.test
# description: test gh:// filesystem with live GitHub network access
# group: [sql]

# Skip when GITHUB_TOKEN is not set (offline CI)
require-env GITHUB_TOKEN

require gh

statement ok
SET autoinstall_known_extensions = true;

statement ok
SET autoload_known_extensions = true;

# Test: explicit branch reads a known public file
query I
SELECT count(*) > 0 FROM read_csv('gh://duckdb/duckdb@main/README.md', header=false, columns={content: VARCHAR});
----
true

# Test: URL without explicit branch resolves default branch and reads same content.
# This exercises the default-branch-resolution code path (the bug that was fixed).
query I
SELECT md5(string_agg(content, '')) = (
    SELECT md5(string_agg(content, ''))
    FROM read_csv('gh://duckdb/duckdb@main/README.md', header=false, columns={content: VARCHAR})
)
FROM read_csv('gh://duckdb/duckdb/README.md', header=false, columns={content: VARCHAR});
----
true

# ── parquet_metadata ─────────────────────────────────────────────────────────
# Exercises GetLastModifiedTime (required by the multi-file infrastructure)
# and the full open/read path for a binary file format.

query I
SELECT count(*) > 0 FROM parquet_metadata('gh://duckdb/duckdb@main/data/parquet-testing/userdata1.parquet');
----
true

# Glob variant: metadata across all top-level parquet files in the directory
query I
SELECT count(*) > 0 FROM parquet_metadata('gh://duckdb/duckdb@main/data/parquet-testing/*.parquet');
----
true

# ── BFS strategy (single-level wildcard, no '**') ────────────────────────────
# Uses Contents API one directory at a time with SegmentMatch pruning.

# Test: single-* glob with explicit branch (BFS path)
query I
SELECT count(*) > 0 FROM glob('gh://duckdb/duckdb@main/data/csv/glob/crawl/d/d00/d10/*.csv');
----
true

# Test: single-* glob without explicit branch (BFS path, default-branch resolution)
query I
SELECT count(*) > 0 FROM glob('gh://duckdb/duckdb/data/csv/glob/crawl/d/d00/d10/*.csv');
----
true

# ── Trees API strategy ('**' pattern) ────────────────────────────────────────
# Uses GET /git/trees/{ref}?recursive=1 — a single API call for the subtree.

# Test: ** glob returns results (Trees API path)
query I
SELECT count(*) > 0 FROM glob('gh://duckdb/duckdb@main/data/csv/glob/**/*.csv');
----
true

# Test: ** glob without explicit branch (Trees API path, default-branch resolution)
query I
SELECT count(*) > 0 FROM glob('gh://duckdb/duckdb/data/csv/glob/**/*.csv');
----
true

# ── BFS exact count regression ───────────────────────────────────────────────
# 4-level wildcard must return all 9 matching files, including the file whose
# parent directory (d40) is processed last and caused a GetFile() early-exit
# bug when ExpandNextPath returned false in the same call that added the file.
query I
SELECT count(*) FROM glob('gh://duckdb/duckdb@main/data/csv/glob/crawl/d/d00/d10/*/*/*/*.csv');
----
9

# ── Cross-check: both strategies agree on a leaf directory ───────────────────
# d40 has no subdirectories, so '*.csv' (BFS) and '**/*.csv' (Trees) must
# match exactly the same set of files (** matches zero path components here).
query I
SELECT
    (SELECT count(*) FROM glob('gh://duckdb/duckdb@main/data/csv/glob/crawl/d/d00/d10/d20/mid/d40/**/*.csv'))
    =
    (SELECT count(*) FROM glob('gh://duckdb/duckdb@main/data/csv/glob/crawl/d/d00/d10/d20/mid/d40/*.csv'));
----
true

# ── HTTP request-count verification ──────────────────────────────────────────
# Verify that each glob strategy makes the expected number of API calls and
# uses only GET requests (never HEAD, POST, or PUT).
#
# Trees API (** pattern): 2 calls.  1 Contents API call to the parent of
# base_dir (data/csv) to resolve base_dir's tree SHA + 1 recursive tree fetch.
#
# BFS (* pattern): one Contents API call per visited directory.  The pattern
# data/csv/glob/crawl/d/d00/d10/*/*/*/*.csv visits 16 directories total.

statement ok
CALL enable_logging('HTTP');

query I
SELECT count(*) FROM glob('gh://duckdb/duckdb@main/data/csv/glob/**/*.csv');
----
174

query I
SELECT count(*) FROM glob('gh://duckdb/duckdb@main/data/csv/glob/crawl/d/d00/d10/*/*/*/*.csv');
----
9

query IIIII
FROM (
    FROM duckdb_logs_parsed('HTTP')
    SELECT count(*),
           sum(request.type == 'HEAD') head,
           sum(request.type == 'GET')  get,
           sum(request.type == 'POST') post,
           sum(request.type == 'PUT')  put
    GROUP BY context_id
    ORDER BY context_id
) WHERE post == 0;
----
2	0	2	0	0
16	0	16	0	0

# ── LIMIT pushdown (BFS) ──────────────────────────────────────────────────────
# GithubGlobResult is a LazyMultiFileList: ExpandNextPath() is called only
# until enough files have been collected to satisfy the LIMIT — remaining
# directories are never visited.  With LIMIT 3, BFS stops after the
# stackoverflow subtree (5 requests) and never enters the d subtree.
# GithubTreesGlobResult fetches the complete subtree in a single recursive
# API call, so LIMIT has no effect on its request count (always 2).

statement ok
CALL enable_logging('HTTP');

# BFS with LIMIT 3: early exit after finding the first 3 matching files
statement ok
SELECT * FROM glob('gh://duckdb/duckdb@main/data/csv/glob/crawl/*/*/*') LIMIT 3;

# BFS without LIMIT: visits all directories in the crawl tree
query I
SELECT count(*) FROM glob('gh://duckdb/duckdb@main/data/csv/glob/crawl/*/*/*');
----
19

# Trees with LIMIT 3: still fetches the whole subtree (2 GETs, same as full)
statement ok
SELECT * FROM glob('gh://duckdb/duckdb@main/data/csv/glob/crawl/**') LIMIT 3;

# Trees without LIMIT: same 2 GETs
query I
SELECT count(*) FROM glob('gh://duckdb/duckdb@main/data/csv/glob/crawl/**');
----
168

# BFS   limited: 5 GETs  (stackoverflow subtree only; d subtree skipped)
# BFS   full:   25 GETs  (all directories visited)
# Trees limited: 2 GETs  (LIMIT does not reduce Trees API request count)
# Trees full:    2 GETs
#
# DESC LIMIT 4 isolates these four queries from any earlier logging context
# in the same test session (prior context_ids are always smaller).
query I
FROM (
    FROM (
        FROM duckdb_logs_parsed('HTTP')
        SELECT context_id, count(*) AS requests
        GROUP BY context_id
        ORDER BY context_id DESC
        LIMIT 4
    )
    ORDER BY context_id
)
SELECT requests;
----
5
25
2
2
