# name: test/sql/quack.test
# description: test gh extension
# group: [sql]

# Require statement will ensure this test is run with this extension loaded
require gh

# Test: secret creation syntax accepted
statement ok
CREATE OR REPLACE SECRET test_gh (TYPE github, TOKEN 'dummy');

# Test: secret is retrievable
query I
SELECT count(*) > 0 FROM duckdb_secrets() WHERE type = 'github';
----
true

