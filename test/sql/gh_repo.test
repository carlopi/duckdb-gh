# name: test/sql/gh_repo.test
# description: test gh_repo() and gh_repos() against the live GitHub API
# group: [sql]

require-env GITHUB_TOKEN

require gh

statement ok
SET autoinstall_known_extensions = true;

statement ok
SET autoload_known_extensions = true;

# ── gh_repo('owner/repo') — single VARCHAR argument ──────────────────────────

# full_name round-trips
query I
SELECT full_name FROM gh_repo('duckdb/duckdb');
----
duckdb/duckdb

# owner field is extracted from owner.login
query I
SELECT owner FROM gh_repo('duckdb/duckdb');
----
duckdb

# Non-private public repo
query I
SELECT "private" FROM gh_repo('duckdb/duckdb');
----
false

# Language
query I
SELECT language FROM gh_repo('duckdb/duckdb');
----
C++

# Numeric field is non-negative
query I
SELECT stargazers_count > 0 FROM gh_repo('duckdb/duckdb');
----
true

# Timestamp is non-null
query I
SELECT created_at IS NOT NULL FROM gh_repo('duckdb/duckdb');
----
true

# ── gh_repos((table)) — table in-out ─────────────────────────────────────────

# Single repo via VALUES
query I
SELECT full_name FROM gh_repos((VALUES ('duckdb/duckdb')));
----
duckdb/duckdb

# Multiple repos: correct row count
query I
SELECT count(*) FROM gh_repos((VALUES ('duckdb/duckdb'), ('duckdb/pg_duckdb')));
----
2

# Multiple repos: names are correct
query I
SELECT name FROM gh_repos((VALUES ('duckdb/duckdb'), ('duckdb/pg_duckdb'))) ORDER BY name;
----
duckdb
pg_duckdb

# From a subquery
query I
SELECT count(*) FROM gh_repos((SELECT unnest(['duckdb/duckdb', 'duckdb/duckdb-wasm'])));
----
2
