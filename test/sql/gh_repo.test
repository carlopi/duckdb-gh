# name: test/sql/gh_repo.test
# description: test gh_repo() and gh_repos() against the live GitHub API
# group: [sql]

require-env GITHUB_TOKEN

require gh

statement ok
SET autoinstall_known_extensions = true;

statement ok
SET autoload_known_extensions = true;

# ── gh_repo('owner/repo') — single repo ──────────────────────────────────────

query I
SELECT full_name FROM gh_repo('duckdb/duckdb');
----
duckdb/duckdb

query I
SELECT owner FROM gh_repo('duckdb/duckdb');
----
duckdb

query I
SELECT "private" FROM gh_repo('duckdb/duckdb');
----
false

query I
SELECT language FROM gh_repo('duckdb/duckdb');
----
C++

query I
SELECT stargazers_count > 0 FROM gh_repo('duckdb/duckdb');
----
true

query I
SELECT created_at IS NOT NULL FROM gh_repo('duckdb/duckdb');
----
true

# ── gh_repo('owner/*') — glob expands to all repos for owner ─────────────────

# carlopi/* returns more than one repo
query I
SELECT count(*) > 1 FROM gh_repo('carlopi/*');
----
true

# every row has a non-empty full_name of the form 'carlopi/...'
query I
SELECT count(*) = count(*) FILTER (WHERE full_name LIKE 'carlopi/%')
FROM gh_repo('carlopi/*');
----
true

# ── gh_repos((table)) — single repo via VALUES ───────────────────────────────

query I
SELECT full_name FROM gh_repos((VALUES ('duckdb/duckdb')));
----
duckdb/duckdb

query I
SELECT count(*) FROM gh_repos((VALUES ('duckdb/duckdb'), ('duckdb/pg_duckdb')));
----
2

query I
SELECT name FROM gh_repos((VALUES ('duckdb/duckdb'), ('duckdb/pg_duckdb'))) ORDER BY name;
----
duckdb
pg_duckdb

# ── gh_repos((table)) — glob row mixed with exact row ────────────────────────

# glob expands carlopi/* plus one exact repo → total > 1
query I
SELECT count(*) > 1 FROM gh_repos((VALUES ('carlopi/*'), ('duckdb/duckdb')));
----
true

# duckdb/duckdb row always present regardless of carlopi/* expansion
query I
SELECT count(*) > 0 FROM gh_repos((VALUES ('carlopi/*'), ('duckdb/duckdb')))
WHERE full_name = 'duckdb/duckdb';
----
true

# ── gh_repos from a subquery ──────────────────────────────────────────────────

query I
SELECT count(*) FROM gh_repos((SELECT unnest(['duckdb/duckdb', 'duckdb/duckdb-wasm'])));
----
2
