# name: test/sql/quack_gh_network.test
# description: test gh:// filesystem with live GitHub network access
# group: [sql]

# Skip when GITHUB_TOKEN is not set (offline CI)
require-env GITHUB_TOKEN

require gh

statement ok
SET autoinstall_known_extensions = true;

statement ok
SET autoload_known_extensions = true;

# Test: explicit branch reads a known public file
query I
SELECT count(*) > 0 FROM read_csv('gh://duckdb/duckdb@main/README.md', header=false, columns={content: VARCHAR});
----
true

# Test: URL without explicit branch resolves default branch and reads same content.
# This exercises the default-branch-resolution code path (the bug that was fixed).
query I
SELECT md5(string_agg(content, '')) = (
    SELECT md5(string_agg(content, ''))
    FROM read_csv('gh://duckdb/duckdb@main/README.md', header=false, columns={content: VARCHAR})
)
FROM read_csv('gh://duckdb/duckdb/README.md', header=false, columns={content: VARCHAR});
----
true

# ── BFS strategy (single-level wildcard, no '**') ────────────────────────────
# Uses Contents API one directory at a time with SegmentMatch pruning.

# Test: single-* glob with explicit branch (BFS path)
query I
SELECT count(*) > 0 FROM glob('gh://duckdb/duckdb@main/data/csv/glob/crawl/d/d00/d10/*.csv');
----
true

# Test: single-* glob without explicit branch (BFS path, default-branch resolution)
query I
SELECT count(*) > 0 FROM glob('gh://duckdb/duckdb/data/csv/glob/crawl/d/d00/d10/*.csv');
----
true

# ── Trees API strategy ('**' pattern) ────────────────────────────────────────
# Uses GET /git/trees/{ref}?recursive=1 — a single API call for the subtree.

# Test: ** glob returns results (Trees API path)
query I
SELECT count(*) > 0 FROM glob('gh://duckdb/duckdb@main/data/csv/glob/**/*.csv');
----
true

# Test: ** glob without explicit branch (Trees API path, default-branch resolution)
query I
SELECT count(*) > 0 FROM glob('gh://duckdb/duckdb/data/csv/glob/**/*.csv');
----
true

# ── Cross-check: both strategies agree on a leaf directory ───────────────────
# d40 has no subdirectories, so '*.csv' (BFS) and '**/*.csv' (Trees) must
# match exactly the same set of files (** matches zero path components here).
query I
SELECT
    (SELECT count(*) FROM glob('gh://duckdb/duckdb@main/data/csv/glob/crawl/d/d00/d10/d20/mid/d40/**/*.csv'))
    =
    (SELECT count(*) FROM glob('gh://duckdb/duckdb@main/data/csv/glob/crawl/d/d00/d10/d20/mid/d40/*.csv'));
----
true
